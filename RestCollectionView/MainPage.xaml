<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RestCollectionView.MainPage">

    <VerticalStackLayout Padding="20" Spacing="15">

        <!-- Button to fetch image -->
        <Button Text="Fetch Random Dog"
                Clicked="OnFetchDogClicked"
                FontAttributes="Bold"
                BackgroundColor="#FFA726"
                TextColor="White"
                CornerRadius="10"/>

        <!-- Loader -->
        <ActivityIndicator x:Name="loader"
                           IsRunning="False"
                           IsVisible="False"
                           HeightRequest="50"/>

        <!-- Image -->
        <Image x:Name="dogImage"
               Aspect="AspectFit"
               HeightRequest="300"
               BackgroundColor="#EEE"
               HorizontalOptions="Center"/>

    </VerticalStackLayout>

</ContentPage>
